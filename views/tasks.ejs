<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Tasks</title>
    <style>
        body {
    font-family: 'Comic Sans MS', cursive, sans-serif;
    background-color: #fdf2f8;
    color: #333;
    margin: 0;
    padding: 0;
}

.container {
    width: 80%;
    margin: 0 auto;
    text-align: center;
}

h1 {
    color: #ff66b2;
    font-size: 2.5rem;
    margin-bottom: 1rem;
}

.soft-input {
    background-color: #fffbf7;
    border: 1px solid #ffd6e8;
    border-radius: 8px;
    padding: 12px;
    margin: 10px 0;
    width: 80%;
    font-size: 1rem;
    color: #333;
}

.soft-button {
    background-color: #ff66b2;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 10px 20px;
    font-size: 1.2rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
}

.soft-button:hover {
    background-color: #ff99cc;
}

.soft-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 2rem;
}

.note {
    margin-top: 1rem;
}

.delete-form {
    margin-top: 1rem;
}

.project-card {
    background-color: #fff;
    border-radius: 12px;
    box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
    margin: 20px;
    padding: 20px;
    text-align: left;
}

.project-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
}

.tasks-body, .projects-body, .login-body, .register-body {
    background-color: #fceaff;
}

    </style>
</head>
<body class="tasks-body">
    <div class="container">
        <h1>Tasks for <%= project.name %></h1>
        <p><%= project.description %></p>
        <ul class="task-list">
            <!-- Aquí puedes iterar sobre las tareas del proyecto -->
            <li>Task 1</li>
            <li>Task 2</li>
            <li>Task 3</li>
        </ul>
        <a href="/proyects" class="soft-button">Back to Projects</a>
    </div>
</body>
</html>
